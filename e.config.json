{
    "host_map": [
        {"host": "xxx", "user": "github-xxx"}
        ],
    "filters": {
        "ignore_dirs": ["node_modules", "__pycache__", "dist", "build", "target", ".git", ".idea", ".vscode", "venv", ".venv", "wheels", ".wrangler", "log", "x"],
        "ignore_files": [".DS_Store", "Thumbs.db", "desktop.ini", "__init__.py", ".python-version", "uv.lock", "package-lock.json", ".env", ".dev.vars", ".log", ".bat"],
        "ignore_exts": [".pyc", ".pyo", ".exe", ".dll", ".obj", ".bin"],
        "include_dot_files": [".github", ".env.example", ".gitignore", ".editorconfig", ".prettierrc"]
    },
    "icons": {
        "full_name": {
            "dockerfile": "🐳",
            "docker-compose.yml": "🐳",
            "package.json": "📦",
            "requirements.txt": "📋",
            "makefile": "🛠️",
            "license": "⚖️",
            "readme.md": "📖"
        },
        "extension": {
            ".py": "🐍", ".js": "🟨", ".ts": "🟦", ".go": "🐹", ".rs": "🦀", 
            ".c": "🛠️", ".cpp": "🛠️", ".java": "☕", ".php": "🐘", ".rb": "💎",
            ".sh": "📜", ".bat": "📜", ".sql": "🗄️", ".lua": "🌙",
            ".html": "🌐", ".css": "🎨", ".json": "⚙️", ".yaml": "⚙️", ".yml": "⚙️",
            ".md": "📝", ".txt": "📄", ".pdf": "📕",
            ".png": "🖼️", ".jpg": "🖼️", ".svg": "🖼️", 
            ".zip": "📦", ".tar": "📦", ".gz": "📦"
        },
        "default": "📄"
    }
}
